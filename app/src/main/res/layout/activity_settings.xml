<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#1976D2"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 设置内容 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ========== 选项卡1 ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选项卡 1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/et_icon1"
                    android:layout_width="56dp"
                    android:layout_height="44dp"
                    android:hint="📊"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/edit_text_bg"
                    android:maxLength="2" />

                <EditText
                    android:id="@+id/et_title1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="标题"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:background="@drawable/edit_text_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <EditText
                android:id="@+id/et_links1"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:hint="链接列表（每行一个）&#10;标题,https://..."
                android:textSize="13sp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/edit_text_bg"
                android:padding="10dp"
                android:layout_marginBottom="8dp" />

            <!-- 操作列表1 -->
            <LinearLayout
                android:id="@+id/actionsContainer1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/btnAddAction1"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+ 添加操作"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:background="@drawable/edit_text_bg"
                android:layout_marginBottom="16dp" />

            <!-- ========== 选项卡2 ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选项卡 2"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/et_icon2"
                    android:layout_width="56dp"
                    android:layout_height="44dp"
                    android:hint="📋"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/edit_text_bg"
                    android:maxLength="2" />

                <EditText
                    android:id="@+id/et_title2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="标题"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:background="@drawable/edit_text_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <EditText
                android:id="@+id/et_links2"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:hint="链接列表（每行一个）&#10;标题,https://..."
                android:textSize="13sp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/edit_text_bg"
                android:padding="10dp"
                android:layout_marginBottom="8dp" />

            <!-- 操作列表2 -->
            <LinearLayout
                android:id="@+id/actionsContainer2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/btnAddAction2"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+ 添加操作"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:background="@drawable/edit_text_bg"
                android:layout_marginBottom="16dp" />

            <!-- ========== 选项卡3 ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选项卡 3"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/et_icon3"
                    android:layout_width="56dp"
                    android:layout_height="44dp"
                    android:hint="➕"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:background="@drawable/edit_text_bg"
                    android:maxLength="2" />

                <EditText
                    android:id="@+id/et_title3"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="标题"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:background="@drawable/edit_text_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <EditText
                android:id="@+id/et_links3"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:hint="链接列表（每行一个）&#10;标题,https://..."
                android:textSize="13sp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/edit_text_bg"
                android:padding="10dp"
                android:layout_marginBottom="8dp" />

            <!-- 操作列表3 -->
            <LinearLayout
                android:id="@+id/actionsContainer3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/btnAddAction3"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="+ 添加操作"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:background="@drawable/edit_text_bg"
                android:layout_marginBottom="24dp" />

            <!-- 帮助说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用说明：\n\n• 元素名填写 CSS 选择器\n• class 用点号：.类名\n• id 用井号：#id名\n• 隐藏：让元素消失\n• 点击：自动触发点击\n• 修改：改变元素文字"
                android:textSize="12sp"
                android:textColor="#999999"
                android:padding="12dp"
                android:background="@drawable/info_bg"
                android:layout_marginBottom="16dp" />

            <!-- 保存按钮 -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="保存设置"
                android:textSize="16sp"
                android:background="@drawable/btn_primary"
                android:textColor="@android:color/white"
                android:textAllCaps="false" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
