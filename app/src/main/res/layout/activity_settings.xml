<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#1976D2"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ========== 关于（放在最上面，默认折叠） ========== -->
            <LinearLayout
                android:id="@+id/aboutSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/aboutHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="关于"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAboutArrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▸"
                        android:textSize="14sp"
                        android:textColor="#999999" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/aboutContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvAboutInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:lineSpacingExtra="4dp" />

                    <TextView
                        android:id="@+id/tvAboutChangelog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvAboutGithub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="查看全部更新日志"
                        android:textSize="12sp"
                        android:textColor="#1976D2"
                        android:paddingTop="8dp"
                        android:paddingBottom="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ========== 网页行为 ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="网页行为"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <!-- 金山文档优化 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="金山文档优化"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="返回键自动关闭金山文档弹窗"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <android.widget.Switch
                    android:id="@+id/switchKdocsOptimize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- 网页暗色模式 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="网页暗色模式"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="通过 CSS 注入让网页变暗色"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <android.widget.Switch
                    android:id="@+id/switchNightModeCSS"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- 页面操作 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="页面操作"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="隐藏/点击/修改页面元素"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <android.widget.Switch
                    android:id="@+id/switchPageActions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- 浏览器标识（UA 切换） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="浏览器标识"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="切换 UA 模拟不同设备"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <Spinner
                    android:id="@+id/spinnerUA"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="120dp" />

            </LinearLayout>

            <!-- ========== 工作区配置 ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="工作区配置"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:id="@+id/settingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ========== 应用设置 ========== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="应用设置"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <!-- 应用名称和图标（双下拉） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:layout_marginBottom="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="应用名称和图标"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">

                    <ImageView
                        android:id="@+id/ivPresetPreview"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:scaleType="fitCenter"
                        android:layout_marginEnd="10dp" />

                    <Spinner
                        android:id="@+id/spinnerGroup"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <Spinner
                        android:id="@+id/spinnerItem"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvPresetInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WebHub1"
                    android:textSize="11sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- ========== 清除缓存 ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="清除缓存"
                        android:textSize="15sp"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/tvCacheSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="计算中..."
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/btnClearCache"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:text="清除"
                    android:textSize="13sp"
                    android:textColor="#F44336"
                    android:background="@drawable/btn_outline_red"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />

            </LinearLayout>

            <!-- 导入导出 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_white"
                android:orientation="horizontal"
                android:padding="10dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/btnExport"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="导出"
                    android:textSize="13sp"
                    android:textColor="#1976D2"
                    android:background="@drawable/btn_outline"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btnImport"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="导入"
                    android:textSize="13sp"
                    android:textColor="#4CAF50"
                    android:background="@drawable/btn_outline_green"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <!-- 保存 -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="保存设置"
                android:textSize="15sp"
                android:background="@drawable/btn_primary"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
