<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_white"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <!-- 选项卡标题栏 -->
    <LinearLayout
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:background="?attr/selectableItemBackground">

        <!-- 拖动手柄 -->
        <TextView
            android:id="@+id/btnDrag"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="☰"
            android:textSize="14sp"
            android:textColor="#BBBBBB"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tvArrow"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="10sp"
            android:textColor="#999999"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvTabIcon"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="📊"
            android:textSize="22sp"
            android:gravity="center" />

        <!-- 显示模式：标题文字 -->
        <TextView
            android:id="@+id/tvTabTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选项卡"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginStart="8dp" />

        <!-- 编辑模式：图标输入 -->
        <EditText
            android:id="@+id/etTabIcon"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:hint="📊"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/input_bg_small"
            android:maxLength="2"
            android:visibility="gone" />

        <!-- 编辑模式：标题输入 -->
        <EditText
            android:id="@+id/etTabTitle"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="选项卡名称"
            android:textSize="14sp"
            android:background="@drawable/input_bg_small"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

        <!-- 确认编辑按钮（编辑模式显示） -->
        <TextView
            android:id="@+id/btnConfirmEdit"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✓ 完成"
            android:textSize="12sp"
            android:textColor="#4CAF50"
            android:background="@drawable/btn_outline_green"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:visibility="gone"
            android:layout_marginStart="8dp" />

        <!-- 更多选项按钮 -->
        <TextView
            android:id="@+id/btnDeleteTab"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="⋮"
            android:textSize="18sp"
            android:textColor="#757575"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- 链接列表容器 -->
    <LinearLayout
        android:id="@+id/linksContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="#F5F5F5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

    <!-- 添加链接按钮 -->
    <TextView
        android:id="@+id/btnAddLink"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="＋ 添加链接"
        android:textSize="13sp"
        android:textColor="#1976D2"
        android:background="?attr/selectableItemBackground"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone" />

</LinearLayout>
