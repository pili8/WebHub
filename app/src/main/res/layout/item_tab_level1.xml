<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_white"
    android:layout_marginBottom="10dp">

    <!-- 选项卡标题栏 -->
    <LinearLayout
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvArrow"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvTabIcon"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="📊"
            android:textSize="20sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvTabTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选项卡"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginStart="6dp" />

        <TextView
            android:id="@+id/btnDeleteTab"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="🗑"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 编辑区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etTabIcon"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:hint="📊"
            android:textSize="18sp"
            android:gravity="center"
            android:background="@drawable/input_bg_small"
            android:maxLength="2" />

        <EditText
            android:id="@+id/etTabTitle"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="选项卡名称"
            android:textSize="13sp"
            android:background="@drawable/input_bg_small"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- 链接列表容器 -->
    <LinearLayout
        android:id="@+id/linksContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:visibility="gone" />

    <!-- 添加链接按钮 -->
    <TextView
        android:id="@+id/btnAddLink"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="+ 添加链接"
        android:textSize="12sp"
        android:textColor="#1976D2"
        android:background="?attr/selectableItemBackground"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

</LinearLayout>
