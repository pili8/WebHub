<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_white"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <!-- 请求名称 -->
    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:hint="请求名称"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/input_bg_small"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginBottom="12dp" />

    <!-- 请求 URL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请求 URL"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etUrl"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:hint="https://api.example.com/data"
        android:textSize="13sp"
        android:inputType="textUri"
        android:background="@drawable/input_bg_small"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginBottom="12dp" />

    <!-- 请求方法 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请求方法"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/rgMethod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/rbGet"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="GET"
            android:textSize="13sp"
            android:button="@null"
            android:gravity="center"
            android:background="@drawable/btn_outline"
            android:layout_marginEnd="8dp" />

        <RadioButton
            android:id="@+id/rbPost"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="POST"
            android:textSize="13sp"
            android:button="@null"
            android:gravity="center"
            android:background="@drawable/btn_primary"
            android:checked="true" />

    </RadioGroup>

    <!-- 请求头 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请求头 (Header)"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etHeaders"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Content-Type: application/json"
        android:textSize="12sp"
        android:inputType="textMultiLine"
        android:gravity="top"
        android:background="@drawable/input_bg_small"
        android:padding="10dp"
        android:layout_marginBottom="12dp" />

    <!-- 请求体 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请求体 (Body) - 使用 {{参数}} 作为占位符"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/etBody"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint='{\n  "key": "{{value}}"\n}'
        android:textSize="12sp"
        android:inputType="textMultiLine"
        android:gravity="top"
        android:background="@drawable/input_bg_small"
        android:padding="10dp"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp" />

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnTest"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="测试"
            android:textSize="12sp"
            android:textColor="#1976D2"
            android:background="@drawable/btn_outline"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="保存"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_primary"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="删除"
            android:textSize="12sp"
            android:textColor="#F44336"
            android:background="@drawable/btn_outline_red"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- 响应结果 -->
    <TextView
        android:id="@+id/tvResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#666666"
        android:fontFamily="monospace"
        android:lineSpacingExtra="2dp"
        android:maxLines="15"
        android:scrollbars="vertical"
        android:layout_marginTop="12dp"
        android:padding="10dp"
        android:background="#F8F9FA"
        android:visibility="gone" />

</LinearLayout>
