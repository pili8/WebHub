<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1565C0"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:id="@+id/btnDropdown"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WebHub"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxWidth="200dp"
                android:ellipsize="end"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tvArrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ▼"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 定时刷新指示器（小绿点） -->
        <View
            android:id="@+id/autoRefreshDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_green"
            android:visibility="gone"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_refresh"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="刷新" />

        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="⋮"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- 搜索栏 -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:padding="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="搜索标题/URL..."
                android:textSize="14sp"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text" />

            <TextView
                android:id="@+id/btnSearchCancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="取消"
                android:textSize="14sp"
                android:textColor="#1976D2"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <CheckBox
                android:id="@+id/cbSearchContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="同时搜索当前页面内容"
                android:textSize="12sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvSearchHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="（较慢，需加载网页）"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 搜索结果 -->
    <LinearLayout
        android:id="@+id/searchResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:visibility="gone" />

    <!-- 下拉列表 -->
    <LinearLayout
        android:id="@+id/dropdownList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:visibility="gone" />

    <!-- 进度条 -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:max="100"
        android:progressDrawable="@drawable/progress_bar"
        android:visibility="gone" />

    <!-- 提示条（查看元素模式） -->
    <TextView
        android:id="@+id/inspectBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF9800"
        android:text="👆 点击页面元素查看标识，再次点击菜单退出"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:padding="8dp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- WebView 内容区 -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white" />

    <!-- 底部子链接菜单（长按工作区时显示） -->
    <LinearLayout
        android:id="@+id/bottomMenuContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:visibility="gone" />

    <!-- 底部工作区 -->
    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal" />

</LinearLayout>
