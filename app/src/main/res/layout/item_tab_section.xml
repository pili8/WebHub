<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp"
    android:background="@drawable/tab_section_bg"
    android:padding="12dp">

    <!-- 选项卡标题（可点击展开/收起） -->
    <LinearLayout
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvArrow"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvTabIcon"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="📊"
            android:textSize="24sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvTabTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选项卡 1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- 编辑区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="图标"
            android:textSize="12sp"
            android:textColor="#999999" />

        <EditText
            android:id="@+id/etTabIcon"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:hint="📊"
            android:textSize="20sp"
            android:gravity="center"
            android:background="@drawable/input_bg"
            android:maxLength="2"
            android:layout_marginStart="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="名称"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginStart="12dp" />

        <EditText
            android:id="@+id/etTabTitle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="选项卡名称"
            android:textSize="14sp"
            android:background="@drawable/input_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- 链接列表容器 -->
    <LinearLayout
        android:id="@+id/linksContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <!-- 添加链接按钮 -->
    <TextView
        android:id="@+id/btnAddLink"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="+ 添加链接"
        android:textSize="13sp"
        android:textColor="#1976D2"
        android:background="@drawable/btn_add_link"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

</LinearLayout>
