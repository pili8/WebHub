<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_gray"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- 链接标题行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etLinkTitle"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:hint="链接标题"
            android:textSize="13sp"
            android:background="@drawable/input_bg_small"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />

        <!-- 更多选项按钮 -->
        <TextView
            android:id="@+id/btnDeleteLink"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="⋮"
            android:textSize="16sp"
            android:textColor="#757575"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="6dp" />

        <!-- 拖动手柄 -->
        <TextView
            android:id="@+id/btnDragLink"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:gravity="center"
            android:text="⠿"
            android:textSize="16sp"
            android:textColor="#CCCCCC"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="2dp" />

    </LinearLayout>

    <!-- 链接网址 -->
    <EditText
        android:id="@+id/etLinkUrl"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:hint="https://..."
        android:textSize="12sp"
        android:inputType="textUri"
        android:background="@drawable/input_bg_small"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginTop="8dp"
        android:singleLine="true" />

    <!-- 桌面模式开关 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="桌面模式"
            android:textSize="11sp"
            android:textColor="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="切换为电脑版网页"
            android:textSize="10sp"
            android:textColor="#999999"
            android:layout_marginEnd="8dp" />

        <android.widget.Switch
            android:id="@+id/switchDesktopMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="0.8"
            android:scaleY="0.8" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp" />

    <!-- 操作标题 + 生效范围 + 添加按钮（点击标题折叠/展开） -->
    <LinearLayout
        android:id="@+id/actionHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:background="?attr/selectableItemBackground"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvActionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="操作"
            android:textSize="12sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/tvActionArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="10sp"
            android:textColor="#999999"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Spinner
            android:id="@+id/spinnerScope"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:background="@drawable/input_bg_small"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btnAddAction"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="＋"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:background="@drawable/btn_outline_green" />

    </LinearLayout>

    <!-- 操作列表容器（默认折叠） -->
    <LinearLayout
        android:id="@+id/actionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

</LinearLayout>
