<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- 定位权限 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 存储权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- 相机权限 -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- 录音权限 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 电话权限 -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- 振动权限 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- NFC 权限 -->
    <uses-permission android:name="android.permission.NFC" />

    <!-- 蓝牙权限 -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />

    <!-- 前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CRMWebView"
        android:usesCleartextTraffic="true">

        <!-- 主 Activity（不作为启动入口，由 alias 代理） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboard|keyboardHidden"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".SettingsActivity"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboard|keyboardHidden"
            android:windowSoftInputMode="adjustResize" />

        <!-- ========== 启动入口别名（7 套预设，仅一个启用） ========== -->

        <!-- 0: WebHub（默认，图标不变） -->
        <activity-alias
            android:name=".AliasWebHub"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="WebHub"
            android:icon="@mipmap/ic_launcher"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 1: ECM（企业CRM） -->
        <activity-alias
            android:name=".AliasECM"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="ECM"
            android:icon="@mipmap/ic_ecm"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 2: LanHub（局域网控制集群） -->
        <activity-alias
            android:name=".AliasLanHub"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="LanHub"
            android:icon="@mipmap/ic_lanhub"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 3: WebHub（自定义图标） -->
        <activity-alias
            android:name=".AliasWebHubPng"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="WebHub"
            android:icon="@mipmap/ic_webhub"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 4: Gming -->
        <activity-alias
            android:name=".AliasGming"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="Gming"
            android:icon="@mipmap/ic_gming"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 5: Pili -->
        <activity-alias
            android:name=".AliasPili"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="Pili"
            android:icon="@mipmap/ic_pili"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 6: PILI（抖音版） -->
        <activity-alias
            android:name=".AliasPiliDouyin"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:label="PILI"
            android:icon="@mipmap/ic_pili_douyin"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
