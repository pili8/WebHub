<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- 定位权限 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 存储权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- 相机权限 -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- 录音权限 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 电话权限 -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- 振动权限 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- NFC 权限 -->
    <uses-permission android:name="android.permission.NFC" />

    <!-- 蓝牙权限 -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />

    <!-- 前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CRMWebView"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboard|keyboardHidden"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".SettingsActivity"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboard|keyboardHidden"
            android:windowSoftInputMode="adjustResize" />

        <!-- ================================================================ -->
        <!-- 分组1：WebHub / LanHub / ECR -->
        <!-- ================================================================ -->

        <activity-alias android:name=".AliasWH1" android:targetActivity=".MainActivity" android:exported="true" android:label="WebHub" android:icon="@mipmap/ic_launcher" android:enabled="true">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasWH2" android:targetActivity=".MainActivity" android:exported="true" android:label="WebHub" android:icon="@mipmap/ic_webhub2" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasWH3" android:targetActivity=".MainActivity" android:exported="true" android:label="WebHub" android:icon="@mipmap/ic_webhub3" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasWH4" android:targetActivity=".MainActivity" android:exported="true" android:label="WebHub" android:icon="@mipmap/ic_webhub4" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasWH5" android:targetActivity=".MainActivity" android:exported="true" android:label="WebHub" android:icon="@mipmap/ic_webhub5" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasWH6" android:targetActivity=".MainActivity" android:exported="true" android:label="WebHub" android:icon="@mipmap/ic_webhub6" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasLH1" android:targetActivity=".MainActivity" android:exported="true" android:label="LanHub" android:icon="@mipmap/ic_lanhub1" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasLH2" android:targetActivity=".MainActivity" android:exported="true" android:label="LanHub" android:icon="@mipmap/ic_lanhub2" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasECR1" android:targetActivity=".MainActivity" android:exported="true" android:label="ECR" android:icon="@mipmap/ic_ecr1" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasECR2" android:targetActivity=".MainActivity" android:exported="true" android:label="ECR" android:icon="@mipmap/ic_ecr2" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasECRcn" android:targetActivity=".MainActivity" android:exported="true" android:label="企业客户记录" android:icon="@mipmap/ic_ecr_cn" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>

        <!-- ================================================================ -->
        <!-- 分组2：Gming / 澎湃浪 / Pili -->
        <!-- ================================================================ -->

        <activity-alias android:name=".AliasGM1" android:targetActivity=".MainActivity" android:exported="true" android:label="Gming" android:icon="@mipmap/ic_gming1" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasGM2" android:targetActivity=".MainActivity" android:exported="true" android:label="Gming" android:icon="@mipmap/ic_gming2" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasGM3" android:targetActivity=".MainActivity" android:exported="true" android:label="Gming" android:icon="@mipmap/ic_gming3" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasPPL" android:targetActivity=".MainActivity" android:exported="true" android:label="澎湃浪" android:icon="@mipmap/ic_ppl" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasPL1" android:targetActivity=".MainActivity" android:exported="true" android:label="Pili" android:icon="@mipmap/ic_pili" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>
        <activity-alias android:name=".AliasPLdy" android:targetActivity=".MainActivity" android:exported="true" android:label="Pili" android:icon="@mipmap/ic_pili_dy" android:enabled="false">
            <intent-filter><action android:name="android.intent.action.MAIN"/><category android:name="android.intent.category.LAUNCHER"/></intent-filter></activity-alias>

    </application>
</manifest>
